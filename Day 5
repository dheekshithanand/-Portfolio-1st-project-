nav {
    background-color: #12121a;
    padding: 16px 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

nav div {
    font-size: 20px;
    font-weight: bold;
    color: white;
}

nav ul {
    list-style: none;
    display: flex;
    gap: 20px;
}

nav a {
    color: white;
    text-decoration: none;
}
